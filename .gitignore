# Dependencies
node_modules/

# Large data files
grifo-crawler/sync/sync-data/*.json
grifo-crawler/sync/sync-logs/*.json
grifo-crawler/*.json

# Keep only dashboard summary
!grifo-crawler/dashboard_summary.json

# Logs
*.log
npm-debug.log*

# Environment files
.env
.env.local
.env.production

# Google service account (Render 에서는 GOOGLE_SERVICE_ACCOUNT_JSON env var 로 주입)
service-account.json
puzzlwhitelisted-*.json

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Temp files
*.tmp
*.temp

# KREAM — 민감 데이터 (로그인 세션·토큰·스크린샷·자격증명)
kream/.browser-data/
kream/kream-tokens.json
kream/kream-error.png
kream/results/login-*.png
kream/explore-output/
kream/explore-output-v2/
kream/explore-output-v3/
kream/explore-output-v4/
kream/explore-search-output/
# KREAM — 이전 실험 산출물 (큰 덤프, 필요 시 개별 force-add)
kream/kream_selling_bids_*.json
# KREAM — 즉석 조회용 임시 입력은 커밋하지 않음
kream/targets-adhoc.json
kream/input-kream-codes.tsv

# 보안 — backup 파일 (과거에 자격증명 노출 사고 발생)
*.backup
*.bak
*.old

# 보안 — 토큰/자격증명 추가 패턴
tokens.json
tokens_*.json
credentials.json
credentials_*.json
*.pem
*.key
*_secret*.json
