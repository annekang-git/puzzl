# KREAM 로그인 자격증명 — 이 파일을 .env 로 복사한 뒤 채워넣으세요.
# .env 는 .gitignore 에 의해 push 되지 않습니다.
KREAM_EMAIL=your-email@example.com
KREAM_PASSWORD=your-password

# Slack 알림용 incoming webhook URL (daily-kream-update.js 가 결과 요약을 전송)
# 없으면 알림 생략. https://api.slack.com/messaging/webhooks 에서 발급.
SLACK_WEBHOOK_URL=

# 한국 residential 프록시 (해외 클라우드 VPS 가 KREAM 에 차단된 경우만 사용)
# Mac mini (한국 IP) 에선 비워두면 됨. Hetzner 등 해외 VPS 는 필수.
# Webshare residential 예시:
#   KREAM_PROXY_SERVER=http://proxy.webshare.io:80
#   KREAM_PROXY_USER=your-username-country-kr
#   KREAM_PROXY_PASS=your-password
KREAM_PROXY_SERVER=
KREAM_PROXY_USER=
KREAM_PROXY_PASS=
